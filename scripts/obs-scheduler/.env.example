# OBS WebSocket (Tools → WebSocket Server Settings в OBS)
OBS_HOST=localhost
OBS_PORT=4455
OBS_PASSWORD=your_obs_password

# Ваш RTMP сервер
RTMP_SERVER=rtmp://localhost/live
RTMP_KEY=wc26

# Адрес вашего API
API_BASE=http://localhost:8080/api

# Базовый URL вашего сайта (что будет в Browser Source)
CAPTURE_BASE_URL=http://localhost:3000

# За сколько минут до матча начинать стрим
START_OFFSET_MIN=5

# Сколько минут после начала останавливать (примерно длина матча)
STOP_OFFSET_MIN=120
