# Copy to .env and fill in your values
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=
ENABLE_DEV_ADMIN_BOOTSTRAP=true
DEFAULT_MIRROR_DOMAIN=
ENV=development
STREAM_SURFACE_PORT=3100
NEXT_PUBLIC_STREAM_SITE_URL=http://localhost:3100

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Frontend dev rewrite target for /hls/* (frontend/next.config.js)
# Example for local docker proxy:
# HLS_PROXY_URL=http://localhost:8089
