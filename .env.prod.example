# Copy to .env.prod and fill in real values. Never commit .env.prod.
# Generate JWT_SECRET: openssl rand -hex 32
JWT_SECRET=change-me-64-char-random-string

# Postgres — used by both docker-compose.yml and the Go backend
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgres://stream:change-me-strong-password@postgres:5432/streamdb?sslmode=disable

# Redis — if empty, no auth is used (dev only)
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@redis:6379

# Telegram alerts (leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Admin seed credentials (used by scripts/seed-admin.sql at first init)
ADMIN_USER=admin
ADMIN_PASS=change-me-admin-password

# App environment
ENV=production
