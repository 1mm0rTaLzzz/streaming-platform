{
  "name": "stream-site-frontend",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:main": "npm run dev -w @stream-site/main",
    "dev:stream": "npm run dev -w @stream-site/stream",
    "dev": "concurrently \"npm:dev:main\" \"npm:dev:stream\"",
    "build": "npm run build -ws --if-present",
    "lint": "npm run lint -ws --if-present",
    "test": "npm run test -ws --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "vitest": "^3.2.4"
  }
}
